# =============================================================================
# WHOP WIRING VALUES — fill these from Bake's Whop dashboard, then run:
#     bash scripts/wire-whop.sh
# First copy this file to `.env.whop.local` (that copy is GITIGNORED — never commit it).
#
# Prices must match config/site.ts:
#   Day $10 · Week $30 · Monthly $100 · Props Pro $150/mo · Coaching from $1,500/mo
# Each checkout link looks like: https://whop.com/checkout/plan_XXXXXXXX
# (Whop → your product → "Checkout link".)
# =============================================================================

NEXT_PUBLIC_WHOP_CHECKOUT_DAY=""
NEXT_PUBLIC_WHOP_CHECKOUT_WEEK=""
NEXT_PUBLIC_WHOP_CHECKOUT_MONTH=""
NEXT_PUBLIC_WHOP_CHECKOUT_PROPS=""
NEXT_PUBLIC_WHOP_CHECKOUT_COACHING=""

# Free Telegram channel invite ("Not ready? Join the free channel →").
NEXT_PUBLIC_FREE_CHANNEL_URL=""

# Webhook signing secret. In Whop → Developer → Webhooks, create a webhook pointed at:
#     https://sports-money-games.vercel.app/api/whop/webhook
# then paste its signing secret here. Server-only (no NEXT_PUBLIC_ prefix).
WHOP_WEBHOOK_SECRET=""

# Public site URL for canonical/OG/sitemap. The production Vercel URL is fine until
# a custom domain is pointed.
NEXT_PUBLIC_SITE_URL="https://sports-money-games.vercel.app"
