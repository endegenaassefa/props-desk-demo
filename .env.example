# =============================================================================
# THE PROPS DESK — environment variables
# Copy this file to `.env.local` and fill in real values. NEVER commit .env.local.
# Everything here is CLIENT-GATED (see HANDOFF.md): it requires the client's own
# Whop account + products. Until these are set, payment CTAs fall back to a
# harmless placeholder and the webhook returns "not configured" (503) instead of
# crashing. Nothing below is wired to a live account yet — UNTESTED-PENDING-CLIENT.
# =============================================================================

# --- Public site URL (used for canonical URLs, sitemap, OG image, robots) -----
# No trailing slash. In Vercel, this is set automatically per-deploy if omitted.
NEXT_PUBLIC_SITE_URL="https://thepropsdesk.com"

# --- WHOP CHECKOUT LINKS ------------------------------------------------------
# One public checkout URL per pricing tier. Create each product/plan in the Whop
# dashboard, then paste its checkout link here. These are PUBLIC links (safe to
# expose to the browser), hence the NEXT_PUBLIC_ prefix.
# Format example: https://whop.com/checkout/plan_XXXXXXXX
NEXT_PUBLIC_WHOP_CHECKOUT_DAY=""
NEXT_PUBLIC_WHOP_CHECKOUT_WEEK=""
NEXT_PUBLIC_WHOP_CHECKOUT_MONTH=""
NEXT_PUBLIC_WHOP_CHECKOUT_PROPS=""
NEXT_PUBLIC_WHOP_CHECKOUT_COACHING=""

# Free Telegram channel invite (the "not ready? join free" link).
NEXT_PUBLIC_FREE_CHANNEL_URL=""

# --- WHOP WEBHOOK (server-only secret — NO NEXT_PUBLIC_ prefix) ---------------
# Set in the Whop dashboard under Developer > Webhooks. Used by
# /api/whop/webhook to verify that incoming events are genuinely from Whop.
# If unset, the webhook endpoint responds 503 "not configured" and verifies nothing.
WHOP_WEBHOOK_SECRET=""

# (Optional) Whop API key + app/agent IDs, if you later confirm Telegram access
# or fetch receipts server-side via the Whop API. Not required for the base build.
WHOP_API_KEY=""
WHOP_APP_ID=""

# --- CRYPTO FALLBACK (NOWPayments) — DOCUMENTED, NOT WIRED --------------------
# Only needed if Whop is ever unavailable. See lib/payments-crypto.ts for the
# commented integration outline. Leave blank unless you deliberately enable it.
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""

# --- ANALYTICS (off by default) ----------------------------------------------
# Set the Plausible domain to enable privacy-friendly analytics. If blank, no
# analytics script is loaded at all.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
# Or, to use Google Analytics instead, set a GA4 measurement ID (G-XXXXXXXXXX).
NEXT_PUBLIC_GA_MEASUREMENT_ID=""
